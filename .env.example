# ─── KIRA — Variables de entorno requeridas ───────────────────────────────────
# Copiá este archivo como .env.local y completá los valores

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL del proyecto (visible en Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon key (pública, va al cliente browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (PRIVADA — nunca exponerla al cliente, solo server-side)
# Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic / Claude API ────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Modelos por módulo (referencia, no modificar salvo intención) ─────────────
# RCA:                    claude-opus-4-5      (razonamiento complejo)
# Visual, Audio, Struct:  claude-sonnet-4-5    (análisis técnico)
# SKF, Manuales:          claude-haiku-4-5 (respuestas rápidas)
